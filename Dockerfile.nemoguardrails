FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/* \
    && python -m pip install --upgrade pip \
    && python -m pip install "nemoguardrails[nvidia]"

EXPOSE 8000

CMD ["nemoguardrails", "server", "--config", "/config", "--port", "8000", "--default-config-id", "nemoclaw"]
