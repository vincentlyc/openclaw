# Local NVIDIA NemoClaw deployment settings
# Copy this file to .env and adjust values before running docker compose.

# Hugging Face token may be required for gated NVIDIA/HF models.
HF_TOKEN=

# vLLM will download and serve this model on the local NVIDIA GPU.
MODEL_ID=nvidia/Llama-3.1-Nemotron-Nano-8B-v1
SERVED_MODEL_NAME=local-nemotron
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=8192
VLLM_PORT=8000

# NeMo Guardrails server port on the host.
GUARDRAILS_PORT=8001

# Non-empty placeholder for OpenAI-compatible local endpoints with no auth.
OPENAI_API_KEY=EMPTY
